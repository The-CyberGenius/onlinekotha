# ============================================
# Kotha environment variables
# Copy to .env and fill in
# ============================================

# REQUIRED
# Long random string to encrypt API keys at rest. Min 32 chars in production.
ENCRYPTION_SECRET=change-me-to-a-long-random-string-at-least-32-characters

# Email which becomes admin on signup
ADMIN_EMAIL=you@example.com

# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# ============================================
# EMAIL (optional — falls back to console output if missing)
# Use any SMTP provider: Resend, Postmark, SendGrid, Mailgun, Gmail, etc.
# ============================================
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASS=re_xxxxx
# EMAIL_FROM=Kotha <noreply@yourdomain.com>

# ============================================
# GOOGLE OAUTH (optional — "Continue with Google" hidden if missing)
# Create OAuth client in Google Cloud Console → APIs & Services → Credentials
# Redirect URI: <PUBLIC_BASE_URL>/api/auth/google/callback
# ============================================
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ============================================
# STRIPE (optional — billing disabled if missing)
# Create products in Stripe dashboard, copy price IDs here
# ============================================
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRO_PRICE_ID=price_xxx       # $5/month subscription
# STRIPE_LIFETIME_PRICE_ID=price_xxx  # $49 one-time
